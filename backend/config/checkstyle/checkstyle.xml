<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Checkstyle configuration based on Google Java Style Guide (AOSP variant – 4-space indent),
    adapted for a Spring Boot + Lombok + MapStruct project.

    Run check:   ./gradlew checkstyleMain
    HTML report: build/reports/checkstyle/main.html
-->
<module name="Checker">
    <property name="severity" value="warning"/>
    <property name="fileExtensions" value="java"/>

    <!-- Skip files generated by annotation processors (e.g. MapStruct) -->
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value=".*[\\/]generated[\\/].*"/>
    </module>

    <!-- File-level rules -->
    <!-- Every file must end with a newline -->
    <module name="NewlineAtEndOfFile"/>
    <!-- No tab characters allowed (Spotless converts them to spaces) -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>
    <!-- Maximum line length: 120 characters (80 per spec, relaxed for Spring Boot annotation verbosity) -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
    </module>
    <!-- Maximum file length: 2000 lines -->
    <module name="FileLength">
        <property name="max" value="2000"/>
    </module>

    <module name="TreeWalker">

        <!-- Imports -->
        <!-- Allow wildcard imports only for verbose annotation-heavy packages -->
        <module name="AvoidStarImport">
            <property name="excludes"
                      value="lombok,jakarta.persistence,org.springframework.web.bind.annotation,pl.edu.ur.teachly.lesson.dto.request"/>
            <property name="allowStaticMemberImports" value="true"/>
        </module>
        <module name="UnusedImports"/>
        <module name="RedundantImport"/>
        <module name="IllegalImport"/>

        <!-- Naming conventions -->
        <!-- Packages: all lowercase -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>
        <!-- Classes: PascalCase -->
        <module name="TypeName"/>
        <!-- Methods and variables: camelCase -->
        <!-- Underscore is allowed in method names – required by Spring Data JPA (e.g. findByTutor_UserId) -->
        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9_]*$"/>
        </module>
        <module name="LocalVariableName"/>
        <module name="LocalFinalVariableName"/>
        <!-- Fields: camelCase (Lombok generates getters/setters automatically) -->
        <module name="MemberName"/>
        <!-- Constants: UPPER_SNAKE_CASE -->
        <module name="ConstantName"/>
        <!-- Method parameters: camelCase -->
        <module name="ParameterName"/>

        <!-- Whitespace and formatting -->
        <module name="WhitespaceAround">
            <!-- Allow empty blocks (e.g. catch(e) {}) -->
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyMethods" value="true"/>
            <property name="allowEmptyTypes" value="true"/>
            <property name="allowEmptyLoops" value="true"/>
        </module>
        <module name="NoWhitespaceBefore"/>
        <module name="ParenPad"/>
        <module name="OperatorWrap"/>

        <!-- Braces -->
        <!-- Braces are mandatory for if/else/for/while/do -->
        <module name="NeedBraces"/>
        <!-- Egyptian brackets style (opening brace on the same line) -->
        <module name="LeftCurly"/>
        <module name="RightCurly"/>

        <!-- Code quality -->
        <!-- No empty catch blocks (unless the variable is named 'ignored' or 'expected') -->
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="ignored|expected"/>
        </module>
        <!-- Cyclomatic complexity limit -->
        <module name="CyclomaticComplexity">
            <property name="max" value="15"/>
        </module>
        <!-- Method length limit -->
        <module name="MethodLength">
            <property name="max" value="100"/>
        </module>
        <!-- Maximum number of method parameters -->
        <module name="ParameterNumber">
            <property name="max" value="8"/>
        </module>
        <!-- Detect empty statements (e.g. stray semicolons) -->
        <module name="EmptyStatement"/>
        <!-- Detect boolean expressions that can be simplified -->
        <module name="SimplifyBooleanExpression"/>
        <module name="SimplifyBooleanReturn"/>
        <!-- Compare Strings with .equals(), not == -->
        <module name="StringLiteralEquality"/>
        <!-- switch must have a default case -->
        <module name="MissingSwitchDefault"/>
        <!-- case without break must have a /* falls through */ comment -->
        <module name="FallThrough"/>

        <!-- Modifiers -->
        <!-- Enforce correct modifier order (public static final ...) -->
        <module name="ModifierOrder"/>
        <!-- Remove redundant 'public' from interface members -->
        <module name="RedundantModifier"/>

        <!-- Javadoc (relaxed – required only on public types) -->
        <!-- Javadoc is NOT enforced: Lombok generates boilerplate that does not need documenting -->
        <!-- Entities, DTOs, and exceptions generally do not need Javadoc -->

        <!-- Miscellaneous -->
        <!-- Java-style array declarations (String[] args, not String args[]) -->
        <module name="ArrayTypeStyle"/>
        <!-- Long numeric literals must use uppercase L (e.g. 100L, not 100l) -->
        <module name="UpperEll"/>

    </module>
</module>
