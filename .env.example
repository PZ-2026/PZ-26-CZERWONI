# Copy this file to .env and fill in the values before running docker-compose

# Database
# User and password for PostgreSQL (used by both db and backend)
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
# Generate a new secret key with command:
#   openssl rand -base64 32 (openssl needed)
# or in powershell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { [byte](Get-Random -Max 256) }))
JWT_SECRET_KEY=

# Token lifetime in milliseconds (default: 24 h)
JWT_EXPIRATION=86400000
